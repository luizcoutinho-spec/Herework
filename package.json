{
  "name": "herework",
  "version": "1.0.0",
  "description": "HereWork — Plataforma de freelancers",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "api/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "dependencies": {
    "nodemailer": "^8.0.10",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
