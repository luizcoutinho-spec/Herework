# ═══════════════════════════════════════════════════════
# HereWork — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════
#
# ATENÇÃO: NÃO commitar o arquivo .env com valores reais!
# Configure estas variáveis no painel do Vercel:
#   vercel.com → Seu Projeto → Settings → Environment Variables
#
# ═══════════════════════════════════════════════════════

# Stripe — Secret Key (NUNCA expor no frontend)
# Obtenha em: https://dashboard.stripe.com/apikeys
# Cole aqui a chave que começa com sk_live_... ou sk_test_...
STRIPE_SECRET_KEY=cole_sua_chave_secreta_aqui

# Stripe — Webhook Secret
# Obtenha em: https://dashboard.stripe.com/webhooks
# Após criar o webhook apontando para: https://herework.com.br/api/webhook
# Cole aqui a chave que começa com whsec_...
STRIPE_WEBHOOK_SECRET=cole_seu_webhook_secret_aqui
